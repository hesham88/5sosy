# Google Cloud — used by ADK / Vertex AI
GOOGLE_CLOUD_PROJECT=khsosy
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Models
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash-lite
GEMINI_MULTIMODAL_MODEL=gemini-1.5-pro

# Vertex AI Vector Search
VERTEX_INDEX_ID=
VERTEX_INDEX_ENDPOINT_ID=
EMBEDDING_MODEL=text-embedding-005

# Storage / DB
FIRESTORE_DATABASE=(default)
FIRESTORE_PROJECT=khsosy
GCS_BUCKET=khsosy.firebasestorage.app

# Service auth: token the Next.js API includes in Authorization: Bearer
AGENTS_SERVICE_TOKEN=

# Local dev port
PORT=8080

# When running locally without ADC, point at service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=./.secrets/serviceAccountKey.json
