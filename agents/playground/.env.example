# Gemini Developer API key (NOT Vertex). Get one at https://aistudio.google.com/apikey
# Copy this file to `.env` and fill in. `.env` is gitignored.
GOOGLE_API_KEY=

# Tell ADK/google-genai to use the Gemini Developer API (not Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Which Gemini model to use across the playground agents
GEMINI_MODEL=gemini-3.1-flash-lite

# Local FastAPI port (Phase 2)
PORT=8080
