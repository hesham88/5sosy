# Firebase web client config (safe to expose — security enforced by Rules + Auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Agents API base URL. When unset, /api/agents/* return simulated payloads.
# After Cloud Run deploy: https://5sosy-agents-<hash>-uc.a.run.app
NEXT_PUBLIC_AGENTS_BASE_URL=

# Server-side only (do NOT prefix with NEXT_PUBLIC_)
AGENTS_SERVICE_TOKEN=
